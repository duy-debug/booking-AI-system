# Groq — free LLM API (tương thích OpenAI SDK)
GROQ_API_KEY=
GROQ_MODEL=mixtral-8x7b-32768
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Local embedding model (sentence-transformers, 384 dim)
EMBED_MODEL_NAME=all-MiniLM-L6-v2
EMBED_DIM=384

# Qdrant — vector database
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=kb_chunks

# Redis — conversation state và pending confirmation
REDIS_URL=redis://localhost:6379/0
CONVERSATION_TTL_SECONDS=1800
BUSINESS_TIMEZONE=Asia/Tokyo

# Booking Backend API
BOOKING_API_URL=http://localhost:8000
BOOKING_API_SERVICE_KEY=

# Admin key cho KB endpoints (POST /api/kb/seed, GET /api/kb/stats)
ADMIN_API_KEY=change-me-in-production

# App
APP_NAME=Booking AI Chatbot
APP_VERSION=0.1.0
CHATBOT_DEBUG=false
CORS_ORIGINS=http://localhost:3000
